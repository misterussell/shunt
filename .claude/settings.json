{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/protect-secrets.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/run_related_test.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(*.env*)",
      "Read(**/*.env*)"
    ]
  }
}
