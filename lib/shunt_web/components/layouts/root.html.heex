<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Shunt" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      // TODO: cut this down to the game's two-mode toggle: only "street" and "corp" are
      // valid values (no "system" — the brief specifies no light mode), and the default
      // when nothing is stored yet must be "street" (per design decision). Concretely:
      //   - drop the `theme === "system"` branch and the `removeAttribute`/`removeItem` path
      //   - change `localStorage.getItem("phx:theme") || "system"` to default to "street"
      //   - the storage-event listener's `|| "system"` fallback becomes `|| "street"`
      // The dispatch mechanism itself (phx:set-theme custom event + data-phx-theme attr,
      // read in layouts.ex's theme_toggle/1) stays as-is per the brief.
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
